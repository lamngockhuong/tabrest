{
  "name": "tabrest",
  "version": "0.5.0",
  "description": "Chrome extension that automatically unloads inactive tabs to free memory",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "format": "biome format src/ --write",
    "validate:manifest": "node scripts/validate-manifest.js",
    "lint:i18n": "node scripts/check-i18n-parity.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm run validate:manifest && pnpm run lint && pnpm run lint:i18n && pnpm run test",
    "build": "node scripts/build.js",
    "build:clean": "rm -rf dist",
    "website:dev": "cd website && pnpm dev",
    "website:build": "cd website && pnpm build",
    "website:preview": "cd website && pnpm preview"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@vitest/coverage-v8": "^4.1.3",
    "esbuild": "0.28.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.3"
}
