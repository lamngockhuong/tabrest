{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.0.5",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "homepage_url": "https://tabrest.ohnice.app",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "system.memory",
    "contextMenus",
    "tabGroups",
    "scripting",
    "idle",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.ingest.us.sentry.io/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "commands": {
    "unload-current": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Unload current tab"
    },
    "unload-others": {
      "suggested_key": {
        "default": "Alt+Shift+O"
      },
      "description": "Unload all other tabs"
    },
    "unload-right": {
      "suggested_key": {
        "default": "Alt+Shift+Right"
      },
      "description": "Unload tabs to the right"
    },
    "unload-left": {
      "suggested_key": {
        "default": "Alt+Shift+Left"
      },
      "description": "Unload tabs to the left"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/watch*"
      ],
      "js": [
        "src/content/youtube-tracker.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
