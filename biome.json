{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": [
      "**/src/**/*.js",
      "**/scripts/**/*.js",
      "**/tests/**/*.js",
      "!**/node_modules/",
      "!**/plans/",
      "!**/docs/",
      "!**/.claude/"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "complexity": {
        "noForEach": "off"
      },
      "style": {
        "useConst": "error"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noVar": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "double"
    },
    "globals": ["chrome"]
  }
}
