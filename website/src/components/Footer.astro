---
// Footer with CTA and links
import { useTranslations, getLocalizedPath, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const locale = (Astro.props.locale || Astro.currentLocale || 'en') as Locale;
const t = useTranslations(locale);
const homeLink = getLocalizedPath('/', locale);
---

<footer class="bg-card-light dark:bg-card-dark border-t border-border-light dark:border-border-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- CTA Section -->
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary dark:text-primary-light mb-4">
        {t.footer.cta.title}
      </h2>
      <p class="text-text-muted dark:text-text-muted-dark mb-6">
        {t.footer.cta.subtitle}
      </p>
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-semibold transition-colors"
      >
        {t.footer.cta.button}
      </a>
    </div>

    <!-- Footer Links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Product -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">{t.footer.sections.product}</h3>
        <ul class="space-y-2">
          <li>
            <a href={`${homeLink}#features`} class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              {t.footer.links.features}
            </a>
          </li>
          <li>
            <a href={`${homeLink}#how-it-works`} class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              {t.footer.links.howItWorks}
            </a>
          </li>
          <li>
            <a href={`${homeLink}#faq`} class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              {t.footer.links.faq}
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">{t.footer.sections.resources}</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              {t.footer.links.github}
            </a>
          </li>
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              {t.footer.links.reportIssue}
            </a>
          </li>
          <li>
            <a
              href="https://chrome.google.com/webstore"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              {t.footer.links.chromeStore}
            </a>
          </li>
          <li>
            <a
              href="/changelog"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              Changelog
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">{t.footer.sections.legal}</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest/blob/main/LICENSE"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              {t.footer.links.license}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-border-light dark:border-border-dark text-center text-sm text-text-muted dark:text-text-muted-dark">
      <p>{t.footer.copyright}</p>
    </div>
  </div>
</footer>
