---
// Footer with CTA and links
---

<footer class="bg-card-light dark:bg-card-dark border-t border-border-light dark:border-border-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- CTA Section -->
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary dark:text-primary-light mb-4">
        Ready to free your memory?
      </h2>
      <p class="text-text-muted dark:text-text-muted-dark mb-6">
        Install TabRest now and experience faster browsing
      </p>
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-semibold transition-colors"
      >
        Add to Chrome - It's Free
      </a>
    </div>

    <!-- Footer Links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Product -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">Product</h3>
        <ul class="space-y-2">
          <li>
            <a href="#features" class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              Features
            </a>
          </li>
          <li>
            <a href="#how-it-works" class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              How It Works
            </a>
          </li>
          <li>
            <a href="#faq" class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors">
              FAQ
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">Resources</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              Report Issue
            </a>
          </li>
          <li>
            <a
              href="https://chrome.google.com/webstore"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              Chrome Web Store
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-primary dark:text-primary-light mb-3">Legal</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/lamngockhuong/tabrest/blob/main/LICENSE"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
            >
              License
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-border-light dark:border-border-dark text-center text-sm text-text-muted dark:text-text-muted-dark">
      <p>© 2026 TabRest. Open source under MIT License.</p>
    </div>
  </div>
</footer>
