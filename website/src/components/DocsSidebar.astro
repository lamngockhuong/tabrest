---
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath, type Locale } from '../i18n';

interface Props {
  currentSlug: string;
  locale?: Locale;
}

const { currentSlug } = Astro.props;
const locale = (Astro.props.locale || Astro.currentLocale || 'en') as Locale;
const t = useTranslations(locale);

// Get docs for current locale (filter by lang prefix once docs are restructured)
const langPrefix = `${locale}/`;
const allDocs = await getCollection('docs', ({ id }) => {
  // Support both flat structure (current) and lang-prefixed structure (future)
  if (id.includes('/')) {
    return id.startsWith(langPrefix);
  }
  // Flat structure - show all for EN, none for VI until restructured
  return locale === 'en';
});

const sortedDocs = allDocs.sort((a, b) => a.data.order - b.data.order);

// Group docs by section
const sections = {
  'getting-started': t.docs.sidebar.sections['getting-started'],
  'features': t.docs.sidebar.sections['features'],
  'reference': t.docs.sidebar.sections['reference'],
} as const;

type SectionKey = keyof typeof sections;

const groupedDocs = sortedDocs.reduce((acc, doc) => {
  const section = doc.data.section as SectionKey;
  if (!acc[section]) {
    acc[section] = [];
  }
  acc[section].push(doc);
  return acc;
}, {} as Record<SectionKey, typeof sortedDocs>);

// Helper to get doc slug without language prefix
const getDocSlug = (id: string) => id.replace(/^(en|vi)\//, '');
---

<nav class="p-4 space-y-6">
  {Object.entries(sections).map(([key, label]) => {
    const sectionDocs = groupedDocs[key as SectionKey] || [];
    if (sectionDocs.length === 0) return null;

    return (
      <div>
        <h3 class="text-sm font-semibold text-text-muted dark:text-text-muted-dark uppercase tracking-wider mb-2">
          {label}
        </h3>
        <ul class="space-y-1">
          {sectionDocs.map(doc => {
            const docSlug = getDocSlug(doc.id);
            const isActive = docSlug === currentSlug || doc.id === currentSlug;
            const href = getLocalizedPath(`/docs/${docSlug}`, locale);
            return (
              <li>
                <a
                  href={href}
                  class={`block px-3 py-2 rounded-md text-sm transition-colors ${
                    isActive
                      ? 'bg-primary/10 dark:bg-primary-light/10 text-primary dark:text-primary-light font-medium'
                      : 'text-text-muted dark:text-text-muted-dark hover:bg-card-light dark:hover:bg-card-dark hover:text-primary dark:hover:text-primary-light'
                  }`}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    );
  })}
</nav>
