---
// Fixed header with navigation, theme toggle, and language switcher
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, getLocalizedPath, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const locale = (Astro.props.locale || Astro.currentLocale || 'en') as Locale;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;
const homeLink = getLocalizedPath('/', locale);

const navLinks = [
  { href: `${homeLink}#features`, label: t.header.features },
  { href: `${homeLink}#how-it-works`, label: t.header.howItWorks },
  { href: `${homeLink}#faq`, label: t.header.faq },
  { href: getLocalizedPath('/docs/getting-started', locale), label: t.header.docs },
  { href: 'https://github.com/lamngockhuong/tabrest', label: t.header.github, external: true },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-sm border-b border-border-light dark:border-border-dark">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={homeLink} class="flex items-center gap-2 font-bold text-xl text-primary dark:text-primary-light hover:opacity-80 transition-opacity">
      <img src="/logo.svg" alt="TabRest" class="w-8 h-8" />
      <span>TabRest</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
        >
          {link.label}
        </a>
      ))}
      <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
      <ThemeToggle />
    </div>

    <!-- Mobile Menu Button & Controls -->
    <div class="md:hidden flex items-center gap-2">
      <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        class="p-2 rounded-lg border border-border-light dark:border-border-dark hover:bg-card-light dark:hover:bg-card-dark transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6 text-text-muted dark:text-text-muted-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="block text-text-muted dark:text-text-muted-dark hover:text-primary dark:hover:text-primary-light transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  if (!window.__headerMenuInit) {
    window.__headerMenuInit = true;
    document.addEventListener('click', (e) => {
      const menu = document.getElementById('mobile-menu');
      if (e.target.closest('#mobile-menu-toggle')) {
        menu?.classList.toggle('hidden');
      } else if (e.target.closest('#mobile-menu a')) {
        menu?.classList.add('hidden');
      }
    });
  }
</script>
