---
// Language switcher - dropdown listing every available locale
import { languages, localeFlags, bcp47, getLocalizedPath, getOtherLocales, type Locale } from '../i18n';

interface Props {
  currentLocale: Locale;
  currentPath: string;
}

const { currentLocale, currentPath } = Astro.props;
const otherLocales = getOtherLocales(currentLocale);
---

<details class="lang-switcher relative">
  <summary
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border-light dark:border-border-dark hover:bg-card-light dark:hover:bg-card-dark transition-colors text-sm font-medium text-text-muted dark:text-text-muted-dark cursor-pointer list-none select-none"
    aria-label="Change language"
  >
    <span class="text-base">{localeFlags[currentLocale]}</span>
    <span class="hidden sm:inline">{languages[currentLocale]}</span>
    <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>

  <ul
    class="absolute right-0 mt-2 min-w-[9rem] py-1 rounded-lg border border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark shadow-lg z-50"
  >
    {otherLocales.map((locale) => (
      <li>
        <a
          href={getLocalizedPath(currentPath, locale)}
          class="flex items-center gap-2 px-3 py-2 text-sm text-text-muted dark:text-text-muted-dark hover:bg-card-light dark:hover:bg-card-dark hover:text-primary dark:hover:text-primary-light transition-colors"
          hreflang={bcp47[locale]}
        >
          <span class="text-base">{localeFlags[locale]}</span>
          <span>{languages[locale]}</span>
        </a>
      </li>
    ))}
  </ul>
</details>

<style>
  .lang-switcher > summary::-webkit-details-marker {
    display: none;
  }
</style>

<script is:inline>
  // Close any open language dropdown when clicking outside of it.
  if (!window.__langSwitcherInit) {
    window.__langSwitcherInit = true;
    document.addEventListener('click', (e) => {
      document.querySelectorAll('details.lang-switcher[open]').forEach((el) => {
        if (!el.contains(e.target)) el.removeAttribute('open');
      });
    });
  }
</script>
