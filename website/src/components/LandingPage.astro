---
// Landing page content - shared between EN and VI
import { useTranslations, type Locale } from '../i18n';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<!-- Hero Section -->
<section class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-16">
  <div class="max-w-4xl mx-auto text-center">
    <img src="/logo.svg" alt="TabRest" class="w-24 h-24 sm:w-32 sm:h-32 mx-auto mb-6" />
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-primary dark:text-primary-light mb-6">
      {t.hero.tagline}
    </h1>
    <p class="text-lg sm:text-xl text-text-muted dark:text-text-muted-dark mb-8 max-w-2xl mx-auto">
      {t.hero.description}
    </p>
    <a
      href="https://chrome.google.com/webstore"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-8 py-4 bg-primary hover:bg-primary-hover text-white text-lg rounded-lg font-semibold transition-colors shadow-lg"
    >
      {t.hero.cta}
    </a>
    <!-- Browser Icons - from github.com/alrra/browser-logos -->
    <div class="mt-6 flex items-center justify-center gap-4 sm:gap-6">
      <!-- Chrome -->
      <div class="browser-icon" title="Chrome">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="-10 -10 276 276">
          <linearGradient id="chrome-a" x1="145" x2="34" y1="253" y2="61" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#1e8e3e"/><stop offset="1" stop-color="#34a853"/></linearGradient>
          <linearGradient id="chrome-b" x1="111" x2="222" y1="254" y2="62" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#fcc934"/><stop offset="1" stop-color="#fbbc04"/></linearGradient>
          <linearGradient id="chrome-c" x1="17" x2="239" y1="80" y2="80" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#d93025"/><stop offset="1" stop-color="#ea4335"/></linearGradient>
          <circle cx="128" cy="128" r="64" fill="#fff"/>
          <path fill="url(#chrome-a)" d="M96 183.4A63.7 63.7 0 0 1 72.6 160L17.2 64A128 128 0 0 0 128 256l55.4-96A64 64 0 0 1 96 183.4Z"/>
          <path fill="url(#chrome-b)" d="M192 128a63.7 63.7 0 0 1-8.6 32L128 256A128 128 0 0 0 238.9 64h-111a64 64 0 0 1 64 64Z"/>
          <circle cx="128" cy="128" r="52" fill="#1a73e8"/>
          <path fill="url(#chrome-c)" d="M96 72.6a63.7 63.7 0 0 1 32-8.6h110.8a128 128 0 0 0-221.7 0l55.5 96A64 64 0 0 1 96 72.6Z"/>
        </svg>
      </div>
      <!-- Edge -->
      <div class="browser-icon" title="Microsoft Edge">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 27600 27600">
          <linearGradient id="edge-a" gradientUnits="userSpaceOnUse"/>
          <linearGradient id="edge-b" x1="6870" x2="24704" y1="18705" y2="18705" href="#edge-a"><stop offset="0" stop-color="#0c59a4"/><stop offset="1" stop-color="#114a8b"/></linearGradient>
          <linearGradient id="edge-c" x1="16272" x2="5133" y1="10968" y2="23102" href="#edge-a"><stop offset="0" stop-color="#1b9de2"/><stop offset=".16" stop-color="#1595df"/><stop offset=".67" stop-color="#0680d7"/><stop offset="1" stop-color="#0078d4"/></linearGradient>
          <radialGradient id="edge-d" cx="16720" cy="18747" r="9538" href="#edge-a"><stop offset=".72" stop-opacity="0"/><stop offset=".95" stop-opacity=".53"/><stop offset="1"/></radialGradient>
          <radialGradient id="edge-e" cx="7130" cy="19866" r="14324" gradientTransform="matrix(.14843 -.98892 .79688 .1196 -8759 25542)" href="#edge-a"><stop offset=".76" stop-opacity="0"/><stop offset=".95" stop-opacity=".5"/><stop offset="1"/></radialGradient>
          <radialGradient id="edge-f" cx="2523" cy="4680" r="20243" gradientTransform="matrix(-.03715 .99931 -2.12836 -.07913 13579 3530)" href="#edge-a"><stop offset="0" stop-color="#35c1f1"/><stop offset=".11" stop-color="#34c1ed"/><stop offset=".23" stop-color="#2fc2df"/><stop offset=".31" stop-color="#2bc3d2"/><stop offset=".67" stop-color="#36c752"/></radialGradient>
          <radialGradient id="edge-g" cx="24247" cy="7758" r="9734" gradientTransform="matrix(.28109 .95968 -.78353 .22949 24510 -16292)" href="#edge-a"><stop offset="0" stop-color="#66eb6e"/><stop offset="1" stop-color="#66eb6e" stop-opacity="0"/></radialGradient>
