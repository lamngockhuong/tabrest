          <path fill="url(#edge-d)" opacity=".35" d="M24105 20053a9345 9345 0 01-1053 472 10202 10202 0 01-3590 646c-4732 0-8855-3255-8855-7432 0-1175 680-2193 1643-2729-4280 180-5380 4640-5380 7253 0 7387 6810 8137 8276 8137 791 0 1984-230 2704-456l130-44a12834 12834 0 006660-5282c220-350-168-757-535-565z"/>
          <path fill="url(#edge-c)" d="M11571 25141a7913 7913 0 01-2273-2137 8145 8145 0 01-1514-4740 8093 8093 0 013093-6395 8082 8082 0 011373-859c312-148 846-414 1554-404a3236 3236 0 012569 1297 3184 3184 0 01636 1866c0-21 2446-7960-8005-7960-4390 0-8004 4166-8004 7820 0 2319 538 4170 1212 5604a12833 12833 0 007684 6757 12795 12795 0 003908 610c1414 0 2774-233 4045-656a7575 7575 0 01-6278-803z"/>
          <path fill="url(#edge-e)" opacity=".4" d="M11571 25141a7913 7913 0 01-2273-2137 8145 8145 0 01-1514-4740 8093 8093 0 013093-6395 8082 8082 0 011373-859c312-148 846-414 1554-404a3236 3236 0 012569 1297 3184 3184 0 01636 1866c0-21 2446-7960-8005-7960-4390 0-8004 4166-8004 7820 0 2319 538 4170 1212 5604a12833 12833 0 007684 6757 12795 12795 0 003908 610c1414 0 2774-233 4045-656a7575 7575 0 01-6278-803z"/>
          <path fill="url(#edge-f)" d="M16231 15886c-80 105-330 250-330 566 0 260 170 512 472 723 1438 1003 4149 868 4156 868a5954 5954 0 003027-839 6147 6147 0 001133-850 6180 6180 0 001910-4437c26-2242-796-3732-1133-4392-2120-4141-6694-6525-11668-6525-7011 0-12703 5635-12798 12620 47-3654 3679-6605 7996-6605 350 0 2346 34 4200 1007 1634 858 2490 1894 3086 2921 618 1067 728 2415 728 2952s-271 1333-780 1990z"/>
          <path fill="url(#edge-g)" d="M16231 15886c-80 105-330 250-330 566 0 260 170 512 472 723 1438 1003 4149 868 4156 868a5954 5954 0 003027-839 6147 6147 0 001133-850 6180 6180 0 001910-4437c26-2242-796-3732-1133-4392-2120-4141-6694-6525-11668-6525-7011 0-12703 5635-12798 12620 47-3654 3679-6605 7996-6605 350 0 2346 34 4200 1007 1634 858 2490 1894 3086 2921 618 1067 728 2415 728 2952s-271 1333-780 1990z"/>
        </svg>
      </div>
      <!-- Brave -->
      <div class="browser-icon" title="Brave">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 2770 2770">
          <linearGradient id="brave-a" y1="51%" y2="51%"><stop offset=".4" stop-color="#f50"/><stop offset=".6" stop-color="#ff2000"/></linearGradient>
          <linearGradient id="brave-b" x1="2%" y1="51%" y2="51%"><stop offset="0" stop-color="#ff452a"/><stop offset="1" stop-color="#ff2000"/></linearGradient>
          <path fill="url(#brave-a)" d="M2395 723l60-147-170-176c-92-92-288-38-288-38l-222-252H992L769 363s-196-53-288 37L311 575l60 147-75 218 250 953c52 204 87 283 234 387l457 310c44 27 98 74 147 74s103-47 147-74l457-310c147-104 182-183 234-387l250-953z"/>
          <path fill="#fff" d="M1935 524s287 347 287 420c0 75-36 94-72 133l-215 230c-20 20-63 54-38 113 25 60 60 134 20 210-40 77-110 128-155 120a820 820 0 01-190-90c-38-25-160-126-160-165s126-110 150-124c23-16 130-78 132-102s2-30-30-90-88-140-80-192c10-52 100-80 167-105l207-78c16-8 12-15-36-20-48-4-183-22-244-5s-163 43-173 57c-8 14-16 14-7 62l58 315c4 40 12 67-30 77-44 10-117 27-142 27s-99-17-142-27-35-37-30-77c4-40 48-268 57-315 10-48 1-48-7-62-10-14-113-40-174-57-60-17-196 1-244 6-48 4-52 10-36 20l207 77c66 25 158 53 167 105 10 53-47 132-80 192s-32 66-30 90 110 86 132 102c24 15 150 85 150 124s-119 140-159 165a820 820 0 01-190 90c-45 8-115-43-156-120-40-76-4-150 20-210 25-60-17-92-38-113l-215-230c-35-37-71-57-71-131s287-420 287-420l273 44c32 0 103-27 168-50 65-20 110-22 110-22s44 0 110 22 136 50 168 50c33 0 275-47 275-47zm-215 1328c18 10 7 32-10 44l-254 198c-20 20-52 50-73 50s-52-30-73-50a13200 13200 0 00-255-198c-16-12-27-33-10-44l150-80a870 870 0 01188-73c15 0 110 34 187 73l150 80z"/>
          <path fill="url(#brave-b)" d="M1999 363l-224-253H992L769 363s-196-53-288 37c0 0 260-23 350 123l276 47c32 0 103-27 168-50 65-20 110-22 110-22s44 0 110 22 136 50 168 50c33 0 275-47 275-47 90-146 350-123 350-123-92-92-288-38-288-38"/>
        </svg>
      </div>
      <!-- Opera -->
      <div class="browser-icon" title="Opera">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 1090 1090">
          <linearGradient id="opera-a" x1="461" x2="461" y1="59" y2="1033" gradientUnits="userSpaceOnUse"><stop offset=".6" stop-color="#ff1b2d"/><stop offset="1" stop-color="#a70014"/></linearGradient>
          <linearGradient id="opera-b" x1="714" x2="714" y1="116" y2="978" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#9c0000"/><stop offset=".7" stop-color="#ff4b4b"/></linearGradient>
          <path fill="url(#opera-a)" d="M545 42.5a502.5 502.5 0 10334.9 877.1 362.4 362.4 0 01-201.4 61.5c-119.7 0-226.8-59.4-299-153-55.6-65.6-91.5-162.5-94-271.3V533c2.5-108.8 38.4-205.8 94-271.3 72-93.6 179.3-153 299-153 73.6 0 142.5 22.5 201.4 61.6a500.8 500.8 0 00-333-127.9h-2z"/>
          <path fill="url(#opera-b)" d="M379.6 261.8c46-54.4 105.7-87.3 170.7-87.3 146.3 0 265 166 265 370.4 0 204.6-118.6 370.4-265 370.4-65 0-124.6-32.8-170.7-87.2 72 93.6 179.2 153 299 153A363 363 0 00880 919.6 501 501 0 001047.5 545a501.1 501.1 0 00-167.6-374.6 362.4 362.4 0 00-201.4-61.5c-119.7 0-226.8 59.4-299 153"/>
        </svg>
      </div>
      <!-- Vivaldi -->
      <div class="browser-icon" title="Vivaldi">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 1900 1900">
          <path fill="#ef3939" d="M944 1830c386 0 600 0 740-140s140-354 140-740 0-600-140-740S1330 70 944 70s-600 0-740 140S64 564 64 950s0 600 140 740 354 140 740 140z"/>
          <path fill="#fff" d="M1407 484a657.9 657.9 0 00-932 0 660.9 660.9 0 000 933 657.9 657.9 0 00932 0 660.9 660.9 0 000-933zm-39 304l-326 567c-20 35-49 56-90 59-45 3-80-16-103-55L519 786c-42-73 5-162 89-166 44-2 78 18 101 57 31 52 61 105 91 158l66 114c33 55 80 85 144 89 90 5 174-60 185-156 1-7 1-14 2-18 0-31-6-57-19-82-34-68 2-143 75-160 60-13 121 31 129 91 4 27-1 52-14 75z"/>
        </svg>
      </div>
      <!-- Arc -->
      <div class="browser-icon" title="Arc">
        <svg class="w-8 h-8 sm:w-10 sm:h-10" viewBox="0 0 82 68">
          <path d="m28.8 51.97 6.35-13.36c-4.85-1.03-9.73-4.03-12.49-7.68l-6.64 13.96c3.69 3.13 8.12 5.59 12.78 7.08" fill="#1a007f"/>
          <path d="M55.3 30.53c-3.19 3.91-7.62 6.81-12.36 7.94l6.33 13.32c4.62-1.56 8.94-4.08 12.67-7.31L55.3 30.53z" fill="#4e000a"/>
          <path d="m16.02 44.89-3.32 6.98c-1.69 3.55-.42 7.92 3.06 9.77 3.69 1.96 8.23.43 10.01-3.3l3.03-6.37a37.885 37.885 0 0 1-12.78-7.08" fill="#1a007f"/>
          <path d="M68.48 15.29a7.29 7.29 0 0 0-8.58 5.72c-.7 3.5-2.34 6.76-4.6 9.53l6.63 13.96c6.12-5.31 10.64-12.54 12.26-20.63.79-3.96-1.77-7.8-5.71-8.58" fill="#ff9396"/>
          <path d="M42.94 38.47c-1.42.34-2.87.52-4.32.52-1.13 0-2.3-.13-3.47-.38-4.85-1.03-9.73-4.03-12.49-7.68-.69-.91-1.25-1.86-1.64-2.83-1.51-3.73-5.76-5.53-9.49-4.03C7.8 25.58 6 29.83 7.5 33.56c1.71 4.24 4.73 8.13 8.52 11.33a37.84 37.84 0 0 0 12.77 7.08c3.21 1.03 6.54 1.6 9.82 1.6 3.64 0 7.23-.63 10.65-1.78l-6.32-13.32z" fill="#002dc8"/>
          <path d="m65.43 51.84-3.5-7.36-6.63-13.95-.01.01s0-.01.01-.01l-9.64-20.28a7.292 7.292 0 0 0-6.58-4.16c-2.81 0-5.37 1.62-6.58 4.16l-9.83 20.68c2.76 3.65 7.64 6.65 12.49 7.68l3.18-6.68c.3-.63 1.2-.63 1.5 0l3.11 6.54h.02-.02l6.33 13.32 3.11 6.54a7.28 7.28 0 0 0 6.59 4.16c.65 0 1.3-.09 1.94-.27 4.39-1.21 6.47-6.26 4.51-10.38" fill="#ff536a"/>
        </svg>
      </div>
    </div>
    <p class="mt-3 text-xs text-text-muted dark:text-text-muted-dark opacity-75">
      {t.hero.subtext}
    </p>
  </div>
</section>

<!-- Problem Section -->
<section id="problem" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-12">
      {t.problem.title}
    </h2>

    <div class="grid md:grid-cols-2 gap-8 items-center">
      <!-- Before -->
      <div class="p-8 rounded-xl border-2 border-danger bg-background-light dark:bg-background-dark">
        <div class="text-4xl mb-4">😰</div>
        <h3 class="text-2xl font-bold text-danger mb-4">{t.problem.before}</h3>
        <ul class="space-y-3 text-text-muted dark:text-text-muted-dark">
          {t.problem.beforeItems.map(item => (
            <li class="flex items-start gap-2">
              <span class="text-danger flex-shrink-0 mt-0.5"><Icon name="x" size={20} strokeWidth={2.5} /></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- After -->
      <div class="p-8 rounded-xl border-2 border-success bg-background-light dark:bg-background-dark">
        <div class="text-4xl mb-4">😌</div>
        <h3 class="text-2xl font-bold text-success mb-4">{t.problem.after}</h3>
        <ul class="space-y-3 text-text-muted dark:text-text-muted-dark">
          {t.problem.afterItems.map(item => (
            <li class="flex items-start gap-2">
              <span class="text-success flex-shrink-0 mt-0.5"><Icon name="check" size={20} strokeWidth={2.5} /></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-2xl sm:text-3xl font-bold text-primary dark:text-primary-light" set:html={t.problem.savings.replace('<highlight>', '<span class="text-success">').replace('</highlight>', '</span>')} />
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.features.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
      {t.features.subtitle}
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.features.items.map(feature => (
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="mb-4 inline-flex items-center justify-center w-12 h-12 rounded-lg bg-primary/10 dark:bg-primary-light/10 text-primary dark:text-primary-light">
            <Icon name={feature.icon} size={28} />
          </div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            {feature.title}
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section id="how-it-works" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.howItWorks.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
      {t.howItWorks.subtitle}
    </p>

    <div class="space-y-8">
      {t.howItWorks.steps.map((step, index) => (
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold">
            {index + 1}
          </div>
          <div>
            <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
              {step.title}
            </h3>
            <p class="text-text-muted dark:text-text-muted-dark">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-semibold transition-colors"
      >
        {t.howItWorks.cta}
      </a>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section id="faq" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
      {t.faq.title}
    </h2>
    <p class="text-center text-text-muted dark:text-text-muted-dark mb-12">
      {t.faq.subtitle}
    </p>

    <div class="space-y-4">
      {t.faq.items.map(item => (
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>{item.question}</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            {item.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .browser-icon {
    opacity: 0.7;
    transition: all 0.2s ease;
    cursor: default;
  }
  .browser-icon:hover {
    opacity: 1;
    transform: scale(1.15);
  }
</style>
