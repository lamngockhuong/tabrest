---
// Changelog page (Vietnamese) - reads from CHANGELOG.md at build time
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

const locale = 'vi';

// Read CHANGELOG.md from project root
const changelogPath = path.join(process.cwd(), '..', 'CHANGELOG.md');
const changelogContent = fs.readFileSync(changelogPath, 'utf-8');
const changelogHtml = marked(changelogContent);
---

<BaseLayout title="Changelog - TabRest" description="See what's new in TabRest" locale={locale}>
  <Header locale={locale} />

  <main class="pt-24 pb-12 px-4 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <article class="changelog-content bg-card-light dark:bg-card-dark rounded-xl p-8 shadow-lg" set:html={changelogHtml} />
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>

<style>
  .changelog-content :global(h1) {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .changelog-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    color: var(--color-text-primary);
  }

  :global(.dark) .changelog-content :global(h2) {
    color: var(--color-text-primary-dark);
  }

  .changelog-content :global(h3) {
    font-size: 1.125rem;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
  }

  :global(.dark) .changelog-content :global(h3) {
    color: var(--color-text-muted-dark);
  }

  .changelog-content :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .changelog-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.625;
    color: var(--color-text-primary);
  }

  :global(.dark) .changelog-content :global(li) {
    color: var(--color-text-primary-dark);
  }

  .changelog-content :global(a) {
    color: var(--color-primary);
  }

  .changelog-content :global(a:hover) {
    text-decoration: underline;
  }

  .changelog-content :global(code) {
    background: var(--color-border-light);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  :global(.dark) .changelog-content :global(code) {
    background: var(--color-border-dark);
  }
</style>
