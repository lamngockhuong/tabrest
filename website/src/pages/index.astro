---
// Landing page - showcases TabRest features and benefits
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="TabRest - Rest your tabs, free your memory">
  <Header />

  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-16">
    <div class="max-w-4xl mx-auto text-center">
      <img src="/logo.svg" alt="TabRest" class="w-24 h-24 sm:w-32 sm:h-32 mx-auto mb-6" />
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-primary dark:text-primary-light mb-6">
        Rest your tabs, free your memory
      </h1>
      <p class="text-lg sm:text-xl text-text-muted dark:text-text-muted-dark mb-8 max-w-2xl mx-auto">
        Automatically unload inactive tabs to reduce memory usage and speed up your browser
      </p>
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-4 bg-primary hover:bg-primary-hover text-white text-lg rounded-lg font-semibold transition-colors shadow-lg"
      >
        Add to Chrome - It's Free
      </a>
      <p class="mt-4 text-sm text-text-muted dark:text-text-muted-dark">
        No account required • Works offline • Open source
      </p>
    </div>
  </section>

  <!-- Problem Section -->
  <section id="problem" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-12">
        The Tab Problem
      </h2>

      <div class="grid md:grid-cols-2 gap-8 items-center">
        <!-- Before -->
        <div class="p-8 rounded-xl border-2 border-danger bg-background-light dark:bg-background-dark">
          <div class="text-4xl mb-4">😰</div>
          <h3 class="text-2xl font-bold text-danger mb-4">Before TabRest</h3>
          <ul class="space-y-3 text-text-muted dark:text-text-muted-dark">
            <li class="flex items-start gap-2">
              <span class="text-danger">❌</span>
              <span>100+ tabs consuming 8GB RAM</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-danger">❌</span>
              <span>Browser freezing and crashing</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-danger">❌</span>
              <span>Slow system performance</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-danger">❌</span>
              <span>Manual tab management nightmare</span>
            </li>
          </ul>
        </div>

        <!-- After -->
        <div class="p-8 rounded-xl border-2 border-success bg-background-light dark:bg-background-dark">
          <div class="text-4xl mb-4">😌</div>
          <h3 class="text-2xl font-bold text-success mb-4">After TabRest</h3>
          <ul class="space-y-3 text-text-muted dark:text-text-muted-dark">
            <li class="flex items-start gap-2">
              <span class="text-success">✅</span>
              <span>Same tabs, only 2GB RAM used</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success">✅</span>
              <span>Smooth browsing experience</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success">✅</span>
              <span>Fast system performance</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success">✅</span>
              <span>Automatic and intelligent</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-2xl sm:text-3xl font-bold text-primary dark:text-primary-light">
          Save up to <span class="text-success">75% memory</span> without closing tabs
        </p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
        Powerful Features
      </h2>
      <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
        Everything you need to manage tabs efficiently
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">⏱️</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Auto-Unload Timer
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Automatically unload tabs after a customizable period of inactivity (10 min to 4 hours)
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">💾</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Memory Threshold
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Trigger unloading when system memory usage reaches your specified threshold (60-90%)
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">🚀</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Startup Unload
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Optionally unload all tabs on browser startup to begin with a clean slate
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">🛡️</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Smart Whitelist
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Protect important tabs with domain-based whitelist and special rules for audio/forms
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">⌨️</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Keyboard Shortcuts
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Quick access via customizable shortcuts: unload current tab, unload others, or unload all
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">📊</div>
          <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
            Usage Statistics
          </h3>
          <p class="text-text-muted dark:text-text-muted-dark">
            Track memory saved and tabs unloaded to see the real impact on your system
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-card-light dark:bg-card-dark">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
        How It Works
      </h2>
      <p class="text-center text-text-muted dark:text-text-muted-dark mb-12 max-w-2xl mx-auto">
        Get started in under 60 seconds
      </p>

      <div class="space-y-8">
        <!-- Step 1 -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold">
            1
          </div>
          <div>
            <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
              Install the Extension
            </h3>
            <p class="text-text-muted dark:text-text-muted-dark">
              Add TabRest from the Chrome Web Store with one click. No account or signup required.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold">
            2
          </div>
          <div>
            <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
              Configure Your Preferences
            </h3>
            <p class="text-text-muted dark:text-text-muted-dark">
              Set your ideal inactivity timer, memory threshold, and whitelist. Or use the smart defaults that work for most users.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold">
            3
          </div>
          <div>
            <h3 class="text-xl font-bold text-primary dark:text-primary-light mb-2">
              Relax and Browse
            </h3>
            <p class="text-text-muted dark:text-text-muted-dark">
              TabRest works silently in the background, automatically managing your tabs. Click any unloaded tab to instantly restore it.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href="https://chrome.google.com/webstore"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-semibold transition-colors"
        >
          Get Started Now
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-primary dark:text-primary-light mb-4">
        Frequently Asked Questions
      </h2>
      <p class="text-center text-text-muted dark:text-text-muted-dark mb-12">
        Everything you need to know about TabRest
      </p>

      <div class="space-y-4">
        <!-- FAQ 1 -->
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>Will I lose my tabs when they're unloaded?</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            No! Unloading tabs is not the same as closing them. The tab stays in your browser with the same URL and position. Click it to instantly reload the page exactly where you left off.
          </p>
        </details>

        <!-- FAQ 2 -->
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>How much memory does TabRest actually save?</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            It depends on the websites, but typically 50-150MB per tab. With 50-100 inactive tabs, you can easily save 5-10GB of RAM. Check the statistics in the extension popup to see your real savings.
          </p>
        </details>

        <!-- FAQ 3 -->
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>Can I prevent certain tabs from being unloaded?</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            Yes! Add domains to your whitelist in the settings. You can also enable automatic protection for tabs playing audio or containing forms with unsaved data.
          </p>
        </details>

        <!-- FAQ 4 -->
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>Does TabRest work offline?</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            Yes! TabRest is a local extension that doesn't require internet connection to function. Your settings and tab data never leave your computer.
          </p>
        </details>

        <!-- FAQ 5 -->
        <details class="group p-6 rounded-xl border border-border-light dark:border-border-dark bg-card-light dark:bg-card-dark">
          <summary class="cursor-pointer font-semibold text-lg text-primary dark:text-primary-light list-none flex items-center justify-between">
            <span>Is TabRest open source?</span>
            <span class="transition-transform group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-4 text-text-muted dark:text-text-muted-dark">
            Yes! TabRest is fully open source under the MIT License. You can review the code, contribute improvements, or report issues on GitHub.
          </p>
        </details>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
