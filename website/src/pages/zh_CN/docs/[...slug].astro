---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { stripLocalePrefix } from '../../../i18n';

export async function getStaticPaths() {
  // Astro lowercases content collection ids, so the prefix is 'zh_cn/' (not 'zh_CN/').
  const docs = await getCollection('docs', ({ id }) => id.startsWith('zh_cn/'));
  return docs.map(doc => ({
    // Remove 'zh_cn/' prefix from URL slug
    params: { slug: stripLocalePrefix(doc.id) },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const locale = 'zh_CN';
---

<DocsLayout
  title={doc.data.title}
  description={doc.data.description}
  currentSlug={stripLocalePrefix(doc.id)}
  locale={locale}
>
  <Content />
</DocsLayout>
